# Homebrew dependencies for building the custom FCEUX fork (Qt6 GUI) that `make test` drives.
# Installed automatically by ./setup.sh, or on demand with:  brew bundle
brew "cmake"        # build system
brew "pkg-config"   # dependency discovery for the FCEUX build
brew "sdl2"         # FCEUX audio/video/input backend
brew "qt"           # Qt6, FCEUX's GUI frontend (Widgets/OpenGL/Network)
brew "minizip"      # required by FCEUX for zip/FDS handling
